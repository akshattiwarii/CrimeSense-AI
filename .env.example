# CrimeSense AI environment template
# Copy this file to .env and fill only the provider you want to use.

# openai, openai_compatible, or ollama
AI_PROVIDER=openai_compatible

# OpenAI-compatible providers such as OpenRouter, Groq, Together, Fireworks, or LM Studio.
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=replace_with_your_provider_key
AI_MODEL=nex-agi/nex-n2-pro:free
AI_HTTP_REFERER=http://127.0.0.1:8000
AI_APP_TITLE=CrimeSense AI

# OpenAI Responses API.
OPENAI_API_KEY=replace_with_your_openai_key
OPENAI_MODEL=gpt-4.1-mini

# Local Ollama.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1

# Keep 20 demo FIR records visible when no complaint data exists.
# Set to 0 in production if you want an empty dashboard.
CRIMESENSE_SEED_SAMPLES=1
